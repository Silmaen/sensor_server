# Persistent storage
DATA_DIR=/data/sensor_server

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://sensors.example.com

# PostgreSQL / TimescaleDB
POSTGRES_DB=sensors
POSTGRES_USER=sensors
POSTGRES_PASSWORD=changeme

# Exposed host ports
WEB_EXPOSED_PORT=8000
MQTT_EXPOSED_PORT=1883

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=backend
MQTT_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# Authentik OIDC (optional — leave OIDC_RP_CLIENT_ID empty to use local login)
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
OIDC_OP_AUTHORIZATION_ENDPOINT=
OIDC_OP_TOKEN_ENDPOINT=
OIDC_OP_USER_ENDPOINT=
OIDC_OP_JWKS_ENDPOINT=
